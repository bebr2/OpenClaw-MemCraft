# Required
MEMORY_SERVER_HOST=127.0.0.1
MEMORY_SERVER_PORT=8765
MEMORY_DATA_DIR=./data_memoryos
MEMORY_STORE_MODULE=memoryos_memory
MEMORY_TOP_K=5
MEMORY_RETRIEVE_MODEL=all-MiniLM-L6-v2
MEMORY_MEMORYOS_USER_ID=default-user
MEMORY_MEMORYOS_ASSISTANT_ID=default-assistant
MEMORY_CONTEXT_MAX_CHARS=4000

# Advanced
MEMORY_MEMORYOS_LLM_MODEL=openclaw
MEMORY_MEMORYOS_SHORT_TERM_CAPACITY=7
MEMORY_MEMORYOS_LONG_TERM_CAPACITY=100
MEMORY_MEMORYOS_MID_TERM_HEAT_THRESHOLD=5

MEMORY_LLM_TASK_ENABLED=true
MEMORY_LLM_GATEWAY_BASE_URL=http://127.0.0.1:18789
MEMORY_LLM_AGENT_ID=memory-compressor
MEMORY_LLM_MODEL=openclaw
MEMORY_LLM_TIMEOUT_MS=120000

MEMORY_LOG_LEVEL=INFO
